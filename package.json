{
  "name": "work-log-3d",
  "type": "module",
  "main": "dist-electron/main/main.js",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "electron:build": "node scripts/electron-build.mjs",
    "electron:dev": "node scripts/electron-dev.mjs",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "vitest run",
    "test:rules": "XDG_CONFIG_HOME=/tmp FIREBASE_SKIP_UPDATE_CHECK=1 firebase emulators:exec --project demo-work-log --only firestore \"vitest run tests/firestore-rules.spec.ts\"",
    "test:watch": "vitest",
    "typecheck": "nuxi typecheck",
    "typecheck:electron": "tsc --noEmit -p tsconfig.electron.json",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "check": "nuxi typecheck && npm run typecheck:electron && npm run lint && npm run format",
    "check:fix": "nuxi typecheck && npm run typecheck:electron && npm run lint:fix && npm run format:fix",
    "verify": "npm run check && npm run test && npm run test:rules",
    "knip": "knip"
  },
  "dependencies": {
    "@firebase/app-types": "^0.9.3",
    "@nuxt/eslint": "^1.15.2",
    "@pinia/nuxt": "^0.11.3",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.7.0",
    "nuxt": "^4.4.2",
    "nuxt-vuefire": "^1.1.0",
    "play-sound": "^1.1.6",
    "vue": "^3.5.30",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "electron": "^41.0.3",
    "electron-vite": "^5.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "firebase-tools": "^15.11.0",
    "jsdom": "^29.0.1",
    "knip": "^6.0.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "vue-tsc": "^3.2.6"
  }
}
