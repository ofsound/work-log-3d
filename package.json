{
  "name": "work-log-3d",
  "type": "module",
  "main": "dist-electron/main/main.js",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "electron:build": "node scripts/electron-build.mjs",
    "electron:dev": "node scripts/electron-dev.mjs",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "nuxi typecheck",
    "typecheck:electron": "tsc --noEmit -p tsconfig.electron.json",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "check": "nuxi typecheck && npm run typecheck:electron && npm run lint && npm run format",
    "check:fix": "nuxi typecheck && npm run typecheck:electron && npm run lint:fix && npm run format:fix",
    "verify": "npm run check && npm run test",
    "knip": "knip"
  },
  "dependencies": {
    "@firebase/app-types": "^0.9.3",
    "@nuxt/eslint": "^1.15.1",
    "@nuxt/fonts": "^0.14.0",
    "@pinia/nuxt": "^0.11.3",
    "firebase": "^12.9.0",
    "firebase-admin": "^13.6.1",
    "nuxt": "^4.3.1",
    "nuxt-vuefire": "^1.1.0",
    "play-sound": "^1.1.6",
    "vue": "^3.5.28",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "electron": "^41.0.3",
    "electron-vite": "^5.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jsdom": "^29.0.1",
    "knip": "^6.0.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.6.0",
    "vitest": "^4.1.0",
    "vue-tsc": "^2.2.0"
  }
}