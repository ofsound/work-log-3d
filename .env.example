# Firebase / VueFire (nuxt-vuefire)
# Copy this file to .env and fill in your values from Firebase Console > Project Settings
# https://console.firebase.google.com/project/YOUR_PROJECT/settings/general

NUXT_PUBLIC_VUEFIRE_CONFIG_API_KEY=
NUXT_PUBLIC_VUEFIRE_CONFIG_AUTH_DOMAIN=
NUXT_PUBLIC_VUEFIRE_CONFIG_PROJECT_ID=
NUXT_PUBLIC_VUEFIRE_CONFIG_STORAGE_BUCKET=
NUXT_PUBLIC_VUEFIRE_CONFIG_MESSAGING_SENDER_ID=
NUXT_PUBLIC_VUEFIRE_CONFIG_APP_ID=

# Required by nuxt-vuefire for SSR + auth (service account path)
# Firebase Console > Project Settings > Service Accounts > Generate new private key
# Place service-account.json in project root (gitignored)
# GOOGLE_APPLICATION_CREDENTIALS=service-account.json
