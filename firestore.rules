rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function hasExactKeys(keys) {
      return request.resource.data.keys().hasAll(keys)
        && request.resource.data.keys().hasOnly(keys);
    }

    function hasExactMapKeys(value, keys) {
      return value is map
        && value.keys().hasAll(keys)
        && value.keys().hasOnly(keys);
    }

    function isNonEmptyString(value) {
      return value is string && value.size() > 0;
    }

    function isHexColor(value) {
      return value is string && value.matches('^#[0-9a-f]{6}$');
    }

    function isNonEmptyList(value) {
      return value is list && value.size() > 0;
    }

    function isStringList(value) {
      return value is list;
    }

    function isNonNegativeInteger(value) {
      return value is int && value >= 0;
    }

    function isNullableNonNegativeInteger(value) {
      return value == null || isNonNegativeInteger(value);
    }

    function isTimestampOrNull(value) {
      return value == null || value is timestamp;
    }

    function isProjectDocument() {
      return hasExactKeys(['name', 'slug', 'notes', 'colors', 'archived'])
        && isNonEmptyString(request.resource.data.name)
        && isNonEmptyString(request.resource.data.slug)
        && request.resource.data.notes is string
        && request.resource.data.archived is bool
        && hasExactMapKeys(request.resource.data.colors, ['primary', 'secondary'])
        && isHexColor(request.resource.data.colors.primary)
        && isHexColor(request.resource.data.colors.secondary);
    }

    function isTagDocument() {
      return hasExactKeys(['name', 'slug'])
        && isNonEmptyString(request.resource.data.name)
        && isNonEmptyString(request.resource.data.slug);
    }

    function isTimeBoxDocument() {
      return hasExactKeys(['startTime', 'endTime', 'notes', 'project', 'tags'])
        && request.resource.data.startTime is timestamp
        && request.resource.data.endTime is timestamp
        && request.resource.data.endTime > request.resource.data.startTime
        && isNonEmptyString(request.resource.data.notes)
        && isNonEmptyString(request.resource.data.project)
        && isStringList(request.resource.data.tags);
    }

    function isReportFilter(value) {
      return hasExactMapKeys(
          value,
          ['dateStart', 'dateEnd', 'projectIds', 'tagIds', 'groupOperator', 'tagOperator']
        )
        && isNonEmptyString(value.dateStart)
        && isNonEmptyString(value.dateEnd)
        && isStringList(value.projectIds)
        && isStringList(value.tagIds)
        && (value.groupOperator == 'intersection' || value.groupOperator == 'union')
        && (value.tagOperator == 'any' || value.tagOperator == 'all');
    }

    function isReportDocument() {
      return hasExactKeys([
          'title',
          'summary',
          'timezone',
          'filters',
          'shareToken',
          'createdAt',
          'updatedAt',
          'publishedAt'
        ])
        && isNonEmptyString(request.resource.data.title)
        && request.resource.data.summary is string
        && isNonEmptyString(request.resource.data.timezone)
        && isReportFilter(request.resource.data.filters)
        && request.resource.data.shareToken is string
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && isTimestampOrNull(request.resource.data.publishedAt);
    }

    function isDailyNoteDocument() {
      return hasExactKeys(['content', 'createdAt', 'updatedAt'])
        && request.resource.data.content is map
        && request.resource.data.content.type == 'doc'
        && request.resource.data.content.content is list
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;
    }

    function isUserSettingsTrayShortcut(item) {
      return item is map
        && item.keys().hasOnly([
          'id',
          'label',
          'timerMode',
          'durationMinutes',
          'project',
          'tags'
        ])
        && item.id is string
        && item.label is string
        && (item.timerMode == 'countup' || item.timerMode == 'countdown')
        && (
          item.durationMinutes == null
          || (item.durationMinutes is int && item.durationMinutes > 0)
        )
        && item.project is string
        && item.tags is list
        && item.tags.size() <= 50;
    }

    function isUserSettingsTrayShortcutsList(list) {
      return list is list
        && list.size() <= 25
        && (list.size() < 1 || isUserSettingsTrayShortcut(list[0]))
        && (list.size() < 2 || isUserSettingsTrayShortcut(list[1]))
        && (list.size() < 3 || isUserSettingsTrayShortcut(list[2]))
        && (list.size() < 4 || isUserSettingsTrayShortcut(list[3]))
        && (list.size() < 5 || isUserSettingsTrayShortcut(list[4]))
        && (list.size() < 6 || isUserSettingsTrayShortcut(list[5]))
        && (list.size() < 7 || isUserSettingsTrayShortcut(list[6]))
        && (list.size() < 8 || isUserSettingsTrayShortcut(list[7]))
        && (list.size() < 9 || isUserSettingsTrayShortcut(list[8]))
        && (list.size() < 10 || isUserSettingsTrayShortcut(list[9]))
        && (list.size() < 11 || isUserSettingsTrayShortcut(list[10]))
        && (list.size() < 12 || isUserSettingsTrayShortcut(list[11]))
        && (list.size() < 13 || isUserSettingsTrayShortcut(list[12]))
        && (list.size() < 14 || isUserSettingsTrayShortcut(list[13]))
        && (list.size() < 15 || isUserSettingsTrayShortcut(list[14]))
        && (list.size() < 16 || isUserSettingsTrayShortcut(list[15]))
        && (list.size() < 17 || isUserSettingsTrayShortcut(list[16]))
        && (list.size() < 18 || isUserSettingsTrayShortcut(list[17]))
        && (list.size() < 19 || isUserSettingsTrayShortcut(list[18]))
        && (list.size() < 20 || isUserSettingsTrayShortcut(list[19]))
        && (list.size() < 21 || isUserSettingsTrayShortcut(list[20]))
        && (list.size() < 22 || isUserSettingsTrayShortcut(list[21]))
        && (list.size() < 23 || isUserSettingsTrayShortcut(list[22]))
        && (list.size() < 24 || isUserSettingsTrayShortcut(list[23]))
        && (list.size() < 25 || isUserSettingsTrayShortcut(list[24]));
    }

    function isUserSettingsDocument() {
      return hasExactKeys(['appearance', 'workflow', 'desktop'])
        && hasExactMapKeys(request.resource.data.appearance, [
            'fontImportUrl',
            'fontFamilies',
            'backgroundPreset'
          ])
        && request.resource.data.appearance.fontImportUrl is string
        && hasExactMapKeys(request.resource.data.appearance.fontFamilies, ['ui', 'data'])
        && isNonEmptyString(request.resource.data.appearance.fontFamilies.ui)
        && isNonEmptyString(request.resource.data.appearance.fontFamilies.data)
        && (
          request.resource.data.appearance.backgroundPreset == 'grid'
          || request.resource.data.appearance.backgroundPreset == 'mist'
          || request.resource.data.appearance.backgroundPreset == 'dusk'
          || request.resource.data.appearance.backgroundPreset == 'aurora'
        )
        && hasExactMapKeys(request.resource.data.workflow, ['hideTags', 'countdownDefaultMinutes'])
        && request.resource.data.workflow.hideTags is bool
        && request.resource.data.workflow.countdownDefaultMinutes is int
        && request.resource.data.workflow.countdownDefaultMinutes > 0
        && request.resource.data.workflow.countdownDefaultMinutes <= 1440
        && hasExactMapKeys(request.resource.data.desktop, ['trayShortcuts'])
        && isUserSettingsTrayShortcutsList(request.resource.data.desktop.trayShortcuts);
    }

    function isActiveTimerDocument() {
      return hasExactKeys([
          'mode',
          'status',
          'startedAtMs',
          'durationSeconds',
          'originalDurationSeconds',
          'pausedAtMs',
          'accumulatedPauseMs',
          'endedAtMs',
          'lastExtensionConsumedSeconds',
          'project',
          'tags',
          'draftNotes',
          'updatedAtMs',
          'updatedByDeviceId',
          'mutationId'
        ])
        && (
          request.resource.data.mode == null
          || request.resource.data.mode == 'countup'
          || request.resource.data.mode == 'countdown'
        )
        && (
          request.resource.data.status == 'idle'
          || request.resource.data.status == 'running'
          || request.resource.data.status == 'paused'
          || request.resource.data.status == 'completed'
        )
        && isNullableNonNegativeInteger(request.resource.data.startedAtMs)
        && isNullableNonNegativeInteger(request.resource.data.durationSeconds)
        && isNullableNonNegativeInteger(request.resource.data.originalDurationSeconds)
        && isNullableNonNegativeInteger(request.resource.data.pausedAtMs)
        && isNonNegativeInteger(request.resource.data.accumulatedPauseMs)
        && isNullableNonNegativeInteger(request.resource.data.endedAtMs)
        && isNonNegativeInteger(request.resource.data.lastExtensionConsumedSeconds)
        && request.resource.data.project is string
        && isStringList(request.resource.data.tags)
        && request.resource.data.draftNotes is string
        && isNonNegativeInteger(request.resource.data.updatedAtMs)
        && request.resource.data.updatedByDeviceId is string
        && isNonNegativeInteger(request.resource.data.mutationId);
    }

    match /users/{uid} {
      allow read, write: if isOwner(uid);
    }

    match /users/{uid}/projects/{projectId} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid) && isProjectDocument();
      allow delete: if isOwner(uid);
    }

    match /users/{uid}/tags/{tagId} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid) && isTagDocument();
      allow delete: if isOwner(uid);
    }

    match /users/{uid}/timeBoxes/{timeBoxId} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid) && isTimeBoxDocument();
      allow delete: if isOwner(uid);
    }

    match /users/{uid}/dailyNotes/{dateKey} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid) && isDailyNoteDocument();
      allow delete: if false;
    }

    match /users/{uid}/reports/{reportId} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid) && isReportDocument();
      allow delete: if isOwner(uid);
    }

    match /users/{uid}/settings/{settingsId} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid) && settingsId == 'preferences' && isUserSettingsDocument();
      allow delete: if false;
    }

    match /users/{uid}/runtime/{runtimeId} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid) && runtimeId == 'activeTimer' && isActiveTimerDocument();
      allow delete: if isOwner(uid) && runtimeId == 'activeTimer';
    }
  }
}
