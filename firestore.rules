rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function hasExactKeys(keys) {
      return request.resource.data.keys().hasAll(keys)
        && request.resource.data.keys().hasOnly(keys);
    }

    function hasExactMapKeys(value, keys) {
      return value is map
        && value.keys().hasAll(keys)
        && value.keys().hasOnly(keys);
    }

    function isNonEmptyString(value) {
      return value is string && value.size() > 0;
    }

    function isHexColor(value) {
      return value is string && value.matches('^#[0-9a-f]{6}$');
    }

    function isNonEmptyList(value) {
      return value is list && value.size() > 0;
    }

    function isStringList(value) {
      return value is list;
    }

    function isTimestampOrNull(value) {
      return value == null || value is timestamp;
    }

    function isProjectDocument() {
      return hasExactKeys(['name', 'slug', 'notes', 'colors'])
        && isNonEmptyString(request.resource.data.name)
        && isNonEmptyString(request.resource.data.slug)
        && request.resource.data.notes is string
        && hasExactMapKeys(request.resource.data.colors, ['primary', 'secondary'])
        && isHexColor(request.resource.data.colors.primary)
        && (
          request.resource.data.colors.secondary == null
          || isHexColor(request.resource.data.colors.secondary)
        );
    }

    function isTagDocument() {
      return hasExactKeys(['name', 'slug'])
        && isNonEmptyString(request.resource.data.name)
        && isNonEmptyString(request.resource.data.slug);
    }

    function isTimeBoxDocument() {
      return hasExactKeys(['startTime', 'endTime', 'notes', 'project', 'tags'])
        && request.resource.data.startTime is timestamp
        && request.resource.data.endTime is timestamp
        && request.resource.data.endTime > request.resource.data.startTime
        && isNonEmptyString(request.resource.data.notes)
        && isNonEmptyString(request.resource.data.project)
        && isStringList(request.resource.data.tags);
    }

    function isReportFilter(value) {
      return hasExactMapKeys(
          value,
          ['dateStart', 'dateEnd', 'projectIds', 'tagIds', 'groupOperator', 'tagOperator']
        )
        && isNonEmptyString(value.dateStart)
        && isNonEmptyString(value.dateEnd)
        && isStringList(value.projectIds)
        && isStringList(value.tagIds)
        && (value.groupOperator == 'intersection' || value.groupOperator == 'union')
        && (value.tagOperator == 'any' || value.tagOperator == 'all');
    }

    function isReportDocument() {
      return hasExactKeys([
          'title',
          'summary',
          'timezone',
          'filters',
          'shareToken',
          'createdAt',
          'updatedAt',
          'publishedAt'
        ])
        && isNonEmptyString(request.resource.data.title)
        && request.resource.data.summary is string
        && isNonEmptyString(request.resource.data.timezone)
        && isReportFilter(request.resource.data.filters)
        && request.resource.data.shareToken is string
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && isTimestampOrNull(request.resource.data.publishedAt);
    }

    function isUserSettingsDocument() {
      return hasExactKeys(['appearance', 'workflow'])
        && hasExactMapKeys(request.resource.data.appearance, [
            'fontImportUrl',
            'fontFamilies',
            'backgroundPreset'
          ])
        && request.resource.data.appearance.fontImportUrl is string
        && hasExactMapKeys(request.resource.data.appearance.fontFamilies, ['ui', 'data', 'script'])
        && isNonEmptyString(request.resource.data.appearance.fontFamilies.ui)
        && isNonEmptyString(request.resource.data.appearance.fontFamilies.data)
        && isNonEmptyString(request.resource.data.appearance.fontFamilies.script)
        && (
          request.resource.data.appearance.backgroundPreset == 'grid'
          || request.resource.data.appearance.backgroundPreset == 'dots'
          || request.resource.data.appearance.backgroundPreset == 'crosshatch'
          || request.resource.data.appearance.backgroundPreset == 'aurora'
        )
        && hasExactMapKeys(request.resource.data.workflow, ['hideTags'])
        && request.resource.data.workflow.hideTags is bool;
    }

    match /users/{uid} {
      allow read, write: if isOwner(uid);
    }

    match /users/{uid}/projects/{projectId} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid) && isProjectDocument();
      allow delete: if isOwner(uid);
    }

    match /users/{uid}/tags/{tagId} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid) && isTagDocument();
      allow delete: if isOwner(uid);
    }

    match /users/{uid}/timeBoxes/{timeBoxId} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid) && isTimeBoxDocument();
      allow delete: if isOwner(uid);
    }

    match /users/{uid}/reports/{reportId} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid) && isReportDocument();
      allow delete: if isOwner(uid);
    }

    match /users/{uid}/settings/{settingsId} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid) && settingsId == 'preferences' && isUserSettingsDocument();
      allow delete: if false;
    }
  }
}
